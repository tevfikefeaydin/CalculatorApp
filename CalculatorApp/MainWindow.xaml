<Window x:Class="CalculatorApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hesap Makinesi" Height="560" Width="320"
        MinHeight="560" MinWidth="320"
        Background="#1C1C1E"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        FontFamily="Segoe UI">

    <Window.Resources>

        <!-- Base look shared by every calculator button: rounded, flat, opacity-based hover/press feedback -->
        <Style x:Key="CalcButtonBase" TargetType="Button">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="18" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.62"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NumberButtonStyle" TargetType="Button" BasedOn="{StaticResource CalcButtonBase}">
            <Setter Property="Background" Value="#2C2C2E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>

        <Style x:Key="FunctionButtonStyle" TargetType="Button" BasedOn="{StaticResource CalcButtonBase}">
            <Setter Property="Background" Value="#A5A5AA"/>
            <Setter Property="Foreground" Value="#1C1C1E"/>
        </Style>

        <Style x:Key="OperatorButtonStyle" TargetType="Button" BasedOn="{StaticResource CalcButtonBase}">
            <Setter Property="Background" Value="#FF9F0A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="24"/>
        </Style>

        <Style x:Key="EqualsButtonStyle" TargetType="Button" BasedOn="{StaticResource OperatorButtonStyle}">
            <Setter Property="FontSize" Value="26"/>
        </Style>

    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Display -->
        <Border Grid.Row="0" Background="#141416" CornerRadius="18" Padding="20,18" Margin="0,0,0,16">
            <StackPanel>
                <TextBlock x:Name="History" Text="" FontSize="16" Foreground="#8E8E93"
                           HorizontalAlignment="Right" Margin="0,0,4,6" Height="20"/>
                <TextBox x:Name="Display" Text="0" FontSize="44" FontWeight="Light"
                         Foreground="White" Background="Transparent" BorderThickness="0"
                         IsReadOnly="True" IsReadOnlyCaretVisible="False"
                         TextAlignment="Right" VerticalContentAlignment="Center"
                         TextWrapping="NoWrap" HorizontalScrollBarVisibility="Hidden"/>
            </StackPanel>
        </Border>

        <!-- Keypad -->
        <UniformGrid Grid.Row="1" Rows="5" Columns="4">
            <Button Content="C" Style="{StaticResource FunctionButtonStyle}" Click="Clear_Click"/>
            <Button Content="⌫" Style="{StaticResource FunctionButtonStyle}" Click="Backspace_Click"/>
            <Button Content="%" Style="{StaticResource FunctionButtonStyle}" Click="Percent_Click"/>
            <Button Content="÷" Tag="/" Style="{StaticResource OperatorButtonStyle}" Click="Operator_Click"/>

            <Button Content="7" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
            <Button Content="8" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
            <Button Content="9" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
            <Button Content="×" Tag="*" Style="{StaticResource OperatorButtonStyle}" Click="Operator_Click"/>

            <Button Content="4" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
            <Button Content="5" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
            <Button Content="6" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
            <Button Content="−" Tag="-" Style="{StaticResource OperatorButtonStyle}" Click="Operator_Click"/>

            <Button Content="1" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
            <Button Content="2" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
            <Button Content="3" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
            <Button Content="+" Tag="+" Style="{StaticResource OperatorButtonStyle}" Click="Operator_Click"/>

            <Button Content="±" Style="{StaticResource FunctionButtonStyle}" Click="SignToggle_Click"/>
            <Button Content="0" Style="{StaticResource NumberButtonStyle}" Click="Number_Click"/>
            <Button Content="." Style="{StaticResource NumberButtonStyle}" Click="Decimal_Click"/>
            <Button Content="=" Style="{StaticResource EqualsButtonStyle}" Click="Equals_Click"/>
        </UniformGrid>
    </Grid>
</Window>
